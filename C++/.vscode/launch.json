{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "g++ build and debug active file",
      "type": "cppdbg",
      "request": "launch",
      // 2단계(tasks.json)에서 만든 exe 파일을 실행
      "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false, // true로 바꾸면 'Hello World'가 새 cmd 창에 뜹니다.
      "MIMode": "gdb",
      "miDebuggerPath": "gdb.exe", // gdb.exe가 환경 변수에 등록되어 있어야 함
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      // 3단계(launch)를 실행하기 전, 2단계(tasks)를 먼저 실행하라는 명령
      "preLaunchTask": "C/C++: g++ build active file"
    }
  ]
}